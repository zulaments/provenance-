-- Variables for Logic
local fastPunchConn
local animPlayedConn
local validNames = { ["1"] = true, ["2"] = true, ["3"] = true, ["4"] = true }
local tracked = {}
local isFastPunchEnabled = false
local fastPunchSpeed = 1

-- Safety check: Update speed only if valid number is typed
fpSpeedBox.FocusLost:Connect(function()
	local num = tonumber(fpSpeedBox.Text)
	if num then
		fastPunchSpeed = num
	else
		-- Revert text to the last valid speed if they type letters
		fpSpeedBox.Text = tostring(fastPunchSpeed)
	end
end)

local function setupAnimator(character)
	local humanoid = character:WaitForChild("Humanoid", 3)
	if not humanoid then return end
	local animator = humanoid:FindFirstChildOfClass("Animator") or Instance.new("Animator", humanoid)

	if animPlayedConn then animPlayedConn:Disconnect() end
	if fastPunchConn then fastPunchConn:Disconnect() end

	tracked = {}

	animPlayedConn = animator.AnimationPlayed:Connect(function(track)
		pcall(function()
			if validNames[track.Name] then
				tracked[track] = true
				track:AdjustSpeed(fastPunchSpeed)
			end
		end)
	end)

	fastPunchConn = RunService.Heartbeat:Connect(function()
		pcall(function()
			for track in pairs(tracked) do
				if track.IsPlaying then
					track:AdjustSpeed(fastPunchSpeed)
				else
					tracked[track] = nil
				end
			end
		end)
	end)
end

fpToggleBtn.MouseButton1Click:Connect(function()
	isFastPunchEnabled = not isFastPunchEnabled
	if isFastPunchEnabled then
		fpToggleBtn.Text = "ON"
		fpToggleBtn.BackgroundColor3 = Color3.fromRGB(161, 179, 180)
		if LocalPlayer.Character then
			setupAnimator(LocalPlayer.Character)
		end
	else
		fpToggleBtn.Text = "OFF"
		fpToggleBtn.BackgroundColor3 = Color3.fromRGB(117, 75, 255)
		if animPlayedConn then animPlayedConn:Disconnect() animPlayedConn = nil end
		if fastPunchConn then fastPunchConn:Disconnect() fastPunchConn = nil end

		pcall(function()
			local character = LocalPlayer.Character
			if not character then return end
			local humanoid = character:FindFirstChildOfClass("Humanoid")
			if not humanoid then return end
			local animator = humanoid:FindFirstChildOfClass("Animator")
			if not animator then return end

			for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
				if validNames[track.Name] then
					track:AdjustSpeed(1)
				end
			end
		end)
	end
end)

LocalPlayer.CharacterAdded:Connect(function(char)
	if isFastPunchEnabled then
		setupAnimator(char)
	end
end)

