local lastCommandTime = 0
local commandCooldown = 0.8
local orbitConnection, standConnection, freezeConnection, benxConnection
local isOrbiting, isHiding, isFrozen, isBenxing = false, false, false, false

local function getHRP(plr)
	local char = plr.Character or plr.CharacterAdded:Wait()
	return char and char:FindFirstChild("HumanoidRootPart")
end

local function safeMoveLocalTo(targetCFrame)
	local hrp = getHRP(LocalPlayer)
	if not hrp then return end
	task.wait(0.04 + math.random() * 0.14)
	local dur = 0.12 + math.random() * 0.18
	pcall(function()
		TweenService:Create(hrp, TweenInfo.new(math.clamp(dur, 0.06, 1.2), Enum.EasingStyle.Linear), {CFrame = targetCFrame}):Play()
	end)
end

local function teleportTo(target)
	local targetHRP = getHRP(target)
	local hrp = getHRP(LocalPlayer)
	if hrp and targetHRP then
		safeMoveLocalTo(targetHRP.CFrame * CFrame.new(3, 0, 0))
	end
end

local orbitData = {enabled = false, angle = 0, radius = 5, speed = math.pi}
local function orbitPlayer(target)
	if orbitConnection then orbitConnection:Disconnect() orbitConnection = nil end
	orbitData.enabled = not orbitData.enabled
	if not orbitData.enabled then return end
	orbitConnection = RunService.Heartbeat:Connect(function(dt)
		local hrp = getHRP(LocalPlayer)
		local targetHRP = getHRP(target)
		if hrp and targetHRP then
			orbitData.angle = orbitData.angle + orbitData.speed * dt * (0.6 + math.random() * 0.8)
			local offset = Vector3.new(math.cos(orbitData.angle) * orbitData.radius, 0, math.sin(orbitData.angle) * orbitData.radius)
			hrp.CFrame = targetHRP.CFrame * CFrame.new(offset)
		end
	end)
end

local function standFloating(target)
	if standConnection then standConnection:Disconnect() end
	standConnection = RunService.Heartbeat:Connect(function()
		local hrp = getHRP(LocalPlayer)
		local targetHRP = getHRP(target)
		if hrp and targetHRP then hrp.CFrame = targetHRP.CFrame * CFrame.new(-1.5, 1.5, 2) end
	end)
end

local function hideInSky()
	local hrp = getHRP(LocalPlayer)
	if hrp then safeMoveLocalTo(CFrame.new(0, 200, 0)) end
end

local function punch()
	local tool = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool")
	if tool then pcall(function() tool:Activate() end) end
end

local function freezePlayer()
	isFrozen = not isFrozen
	if isFrozen then
		local hrp = getHRP(LocalPlayer)
		if hrp then
			freezeConnection = RunService.Stepped:Connect(function()
				if isFrozen and hrp:IsDescendantOf(workspace) then
					hrp.AssemblyLinearVelocity = Vector3.new(0,0,0)
					hrp.AssemblyAngularVelocity = Vector3.new(0,0,0)
					local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
					if hum then hum.PlatformStand = true end
				end
			end)
		end
	else
		if freezeConnection then freezeConnection:Disconnect() freezeConnection = nil end
		local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
		if hum then hum.PlatformStand = false end
	end
end

local function benxPlayer(target)
	if benxConnection then benxConnection:Disconnect() benxConnection = nil end
	isBenxing = not isBenxing
	if not isBenxing then return end
	local offset, dir = -1.5, 1
	benxConnection = RunService.Heartbeat:Connect(function()
		local hrp = getHRP(LocalPlayer)
		local targetHRP = getHRP(target)
		if hrp and targetHRP then
			offset = offset + dir * 0.25
			if offset > -0.5 then dir = -1 elseif offset < -2.5 then dir = 1 end
			hrp.CFrame = targetHRP.CFrame * CFrame.new(0, 0, offset)
		end
	end)
end

local function stopAll()
	if orbitConnection then orbitConnection:Disconnect() orbitConnection = nil end
	if standConnection then standConnection:Disconnect() standConnection = nil end
	if freezeConnection then freezeConnection:Disconnect() freezeConnection = nil end
	if benxConnection then benxConnection:Disconnect() benxConnection = nil end
	isFrozen = false
	local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
	if hum then hum.PlatformStand = false end
end

local function handleCommand(cmd, issuer)
	if tick() - lastCommandTime < commandCooldown then return end
	lastCommandTime = tick()
	if cmd == "!bring" then teleportTo(issuer)
	elseif cmd == "!orbit" then orbitPlayer(issuer)
	elseif cmd == "!stand" then standFloating(issuer)
	elseif cmd == "!hide" then hideInSky()
	elseif cmd == "!punch" then punch()
	elseif cmd == "!freeze" then freezePlayer()
	elseif cmd == "!benx" then benxPlayer(issuer)
	elseif cmd == "!reset" or cmd == "!stop" then stopAll()
	elseif cmd == "!kick" then LocalPlayer:Kick("kicked by aspect")
	elseif cmd == "!rejoin" then TeleportService:Teleport(PlaceId)
	end
end

local function monitorChatUI()
	if not commandListenerEnabled then return end
	local list
	local tries = 0
	while not list and tries < 40 do
		local mainGui = PlayerGui:FindFirstChild("Main")
		if mainGui then list = mainGui:FindFirstChild("List", true) end
		tries += 1
		task.wait(0.25)
	end
	if not list then return end
	local function watchTextLabel(lbl)
		if not lbl or not lbl:IsA("TextLabel") then return end
		local function checkText()
			local txt = lbl.Text:lower()
			if not txt:find("!") then return end
			local matchingUsers = {}
			for id in pairs(commandUserIds) do
				local u = Players:GetPlayerByUserId(id)
				if u and txt:find(u.Name:lower()) then table.insert(matchingUsers, u) end
			end
			if #matchingUsers == 0 then return end
			local issuer = matchingUsers[1]
			for _, u in ipairs(matchingUsers) do
				if u.UserId == higherAuthorityId then issuer = u break end
			end
			local cmdword = txt:match("!(%w+)")
			if cmdword then handleCommand("!" .. cmdword, issuer) end
		end
		pcall(checkText)
		lbl:GetPropertyChangedSignal("Text"):Connect(checkText)
	end
	list.DescendantAdded:Connect(function(desc) pcall(function() watchTextLabel(desc) end) end)
	for _, lbl in ipairs(list:GetDescendants()) do pcall(function() watchTextLabel(lbl) end) end
end
task.spawn(monitorChatUI)
